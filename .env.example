# ── Monkey Wrench Ops — environment ──
# Copy this file to ".env" is NOT needed (the app reads real env vars).
# On most setups you just export these before "npm start", or set them
# in your host's dashboard. Defaults work out of the box for local use.

# Port the server listens on
PORT=3000

# Secret used to sign login tokens. CHANGE THIS to a long random string
# in production (e.g. run:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))")
JWT_SECRET=please-change-me-to-a-long-random-string

# Only emails ending in @THIS_DOMAIN can sign in or be created.
OFFICE_DOMAIN=monkeywrench.in

# Password assigned to every seeded user on first run.
# Everyone is forced to change it at first sign-in.
SEED_PASSWORD=changeme123

# Set to "production" when you deploy (enables secure cookies — requires HTTPS).
NODE_ENV=development

# Where the SQLite database file is stored. Leave unset for local use.
# On a cloud host, point this at your mounted persistent disk, e.g. /var/data
# DATA_DIR=/var/data

# ── Database encryption at rest (optional) ──────────────────────────
# Set a long secret to encrypt the WHOLE database file with SQLCipher.
# Requires the optional module "better-sqlite3-multiple-ciphers" (bundled
# as an optional dependency; installed automatically when it can build).
# WARNING: keep this key safe — without it the database cannot be opened,
# and the key cannot be changed on an existing file. To rotate it: export
# a backup from Data management, reset with the new key set, then restore.
# If this is unset (or the module is unavailable) the app runs unencrypted.
# DB_ENCRYPTION_KEY=

# ── Email for Super-Admin password reset (optional) ─────────────────
# The Super-Admin "reset by email" flow sends a 6-digit code. If SMTP is
# left unset, the code is printed to the server log instead (fine for local
# / small setups). nodemailer is an optional dependency, required lazily.
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587                 # 587 = STARTTLS (most common), 465 = TLS
# SMTP_SECURE=false             # "true" only for port 465
# SMTP_USER=apikey-or-username
# SMTP_PASS=your-smtp-password-or-api-key
# SMTP_FROM=no-reply@monkeywrench.in   # the visible "From" address
